# Football Predictor AI - Environment Variables
# ==============================================

# API-Football Key (required)
# Get a free key at: https://www.api-football.com/
# Or via RapidAPI: https://rapidapi.com/api-sports/api/api-football
APIFOOTBALL_API_KEY=your_api_key_here

# API Host (optional - defaults to api-sports.io direct)
# For RapidAPI: APIFOOTBALL_HOST=api-football-v1.p.rapidapi.com
APIFOOTBALL_HOST=v3.football.api-sports.io

# Rate limiting (requests per minute)
API_RATE_LIMIT_PER_MINUTE=10

# Cache TTL in seconds (default: 6 hours)
CACHE_TTL_SECONDS=21600

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── The Odds API (for real bookmaker odds) ──
# Free tier: 500 requests/month
# Get a key at: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here
